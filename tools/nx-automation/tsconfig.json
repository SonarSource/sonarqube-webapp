{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "declaration": true,
    // This is a CommonJS Node package (see package.json "type"); emit CJS and
    // resolve accordingly instead of inheriting the base ESNext/bundler setup.
    "module": "node16",
    "moduleResolution": "node16",
    "types": ["node", "jest"]
  },
  "files": [],
  "include": ["src/**/*"]
}
